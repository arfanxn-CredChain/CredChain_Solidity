PRIVATE_KEY=your_private_key
POLYGON_RPC_URL=https://polygon-rpc.com/
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com/

# [REQUIRED] The address that will receive the SuperAdmin role during deployment
# This address must be controlled by you as it will have the highest privilege level
# Format: 0x followed by 40 hexadecimal characters (20 bytes)
INITIAL_SUPER_ADMIN_WALLET_ADDRESS=0x1234567890123456789012345678901234567890

# Anvil config (local dev chain with state persistence)
# Anvil runs as a Docker service — start with:
#   cd ../CredChain_Golang && docker compose up -d anvil
# Anvil listens on http://127.0.0.1:8545
# State is saved to ../CredChain_Golang/docker/anvil/data/state.json
#
# The SuperAdmin address for INITIAL_SUPER_ADMIN_WALLET_ADDRESS is the Hardhat
# mnemonic account #1 (Muhammad Arfan):
#   INITIAL_SUPER_ADMIN_WALLET_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
#
# Deploy contracts via Hardhat:
#   npx hardhat run scripts/deploy.ts --network localhost
